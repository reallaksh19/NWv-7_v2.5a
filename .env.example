# API Keys for News & Weather App

# Optional: Key for NewsData.io (if using premium fallback)
VITE_NEWS_API_KEY=

# Optional: Key for Weather Provider (if not using Open-Meteo)
VITE_WEATHER_API_KEY=

# Optional: DuckDuckGo proxy key (if applicable)
VITE_DDG_API_KEY=

# Optional: preferred dataset API base URL for static frontend builds.
# Example: https://dataset-api.example.com
# Do not include a trailing /api/datasets/upAhead path; the client appends it.
# Leave unset to use static snapshot fallback.
VITE_API_BASE_URL=

# Optional: backward-compatible API base URL fallback.
# Prefer VITE_API_BASE_URL for dataset API configuration.
# Do not include a trailing /api/datasets/upAhead path; the client appends it.
# Leave unset to use static snapshot fallback.
VITE_BACKEND_URL=
